def minimax(depth, isMax):
    if depth == 0:
        return 1

    if isMax:
        best = -1000
        for i in range(2):
            val = minimax(depth - 1, False)
            best = max(best, val)
        return best
    else:
        best = 1000
        for i in range(2):
            val = minimax(depth - 1, True)
            best = min(best, val)
        return best

print(minimax(3, True))
